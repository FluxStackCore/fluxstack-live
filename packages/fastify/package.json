{
  "name": "@fluxstack/live-fastify",
  "version": "0.1.0",
  "description": "Fastify transport adapter for @fluxstack/live",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluxstack/live": "^0.1.0",
    "@fluxstack/live-client": "^0.1.0",
    "fastify-plugin": "^5.0.0"
  },
  "peerDependencies": {
    "fastify": ">=4.0.0",
    "@fastify/websocket": ">=10.0.0"
  },
  "devDependencies": {
    "fastify": "^5.2.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "@types/ws": "^8.5.0",
    "ws": "^8.18.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FluxStackCore/fluxstack-live",
    "directory": "packages/fastify"
  },
  "license": "MIT"
}
